{
  "name": "docs-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "site",
    "tools/importer"
  ],
  "scripts": {
    "site:dev": "npm --workspace site run dev",
    "site:build": "npm --workspace site run build",
    "site:preview": "npm --workspace site run preview",
    "site:qa": "npm --workspace site run qa",
    "import:discover": "npm --workspace @docs-test/importer run discover --",
    "import:fetch": "npm --workspace @docs-test/importer run fetch --",
    "import:convert": "npm --workspace @docs-test/importer run convert --",
    "import:qa": "npm --workspace @docs-test/importer run qa --",
    "import:all": "npm --workspace @docs-test/importer run all --",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "lint": "prettier . --check && npm --workspaces --if-present run lint",
    "test": "npm --workspaces --if-present test"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
